<div class="card">
  <%= link_to prototype_path(prototype) do %>
    <% if prototype.image.attached? %>
      <%= image_tag prototype.image, class: :card__img %>
    <% else %>
      <div class="card__img" style="background: #f0f0f0; height: 200px; display: flex; align-items: center; justify-content: center; color: #999;">画像なし</div>
    <% end %>
  <% end %>
  <div class="card__body">
    <%= link_to prototype.title, prototype_path(prototype), class: :card__title %>
    <p class="card__summary">
      <%= prototype.catch_copy %>
    </p>
    <%= link_to "by #{prototype.user.name}", user_path(prototype.user), class: :card__user %>
  </div>
</div>
